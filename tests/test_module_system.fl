// Phase 20: Module System - 30개 무관용 테스트
// 모듈 및 패키지 시스템 완전 검증

module test_module_system

use module_system::{
    Visibility, ModuleMetadata, Module, ModuleTree,
    ImportPath, Import, ReExport,
    Crate, Namespace, Prelude, CompleteModuleSystem
}

// Test 1: Visibility enum
fn test_visibility_public() {
    let vis = Visibility::Public
    assert(true, "visibility public should be defined")
}

// Test 2: Module creation
fn test_module_creation() {
    let module = Module::new("mymodule", "/mymodule")
    assert(module.metadata.name == "mymodule", "module name should be set")
    assert(module.metadata.path == "/mymodule", "module path should be set")
}

// Test 3: Module visibility
fn test_module_visibility() {
    let mut module = Module::new("test", "/test")
    module.set_visibility(Visibility::Public)
    assert(module.is_public(), "module should be public")
}

// Test 4: Module parent
fn test_module_parent() {
    let mut module = Module::new("child", "/parent/child")
    module.set_parent("parent")
    assert(module.metadata.parent == "parent", "parent should be set")
}

// Test 5: Module add child
fn test_module_add_child() {
    let mut module = Module::new("parent", "/parent")
    module.add_child("child1")
    assert(module.child_count() == 1, "should have 1 child")
}

// Test 6: Module add item
fn test_module_add_item() {
    let mut module = Module::new("test", "/test")
    module.add_item("fn add")
    assert(module.item_count() == 1, "should have 1 item")
}

// Test 7: Module add export
fn test_module_add_export() {
    let mut module = Module::new("test", "/test")
    module.add_export("add")
    assert(module.exports.len() == 1, "should have 1 export")
}

// Test 8: ModuleTree creation
fn test_module_tree_creation() {
    let tree = ModuleTree::new()
    assert(tree.module_count() == 1, "tree should have root module")
}

// Test 9: ModuleTree register module
fn test_module_tree_register() {
    let mut tree = ModuleTree::new()
    let module = Module::new("test", "/test")
    tree.register_module(module)
    assert(tree.module_count() == 2, "tree should have 2 modules")
}

// Test 10: ModuleTree module exists
fn test_module_tree_exists() {
    let mut tree = ModuleTree::new()
    let module = Module::new("mymod", "/mymod")
    tree.register_module(module)
    assert(tree.module_exists("mymod"), "mymod should exist")
}

// Test 11: ImportPath creation
fn test_import_path_creation() {
    let path = ImportPath::new()
    assert(path.segment_count() == 0, "path should have 0 segments initially")
}

// Test 12: ImportPath add segment
fn test_import_path_add_segment() {
    let mut path = ImportPath::new()
    path.add_segment("std")
    path.add_segment("io")
    assert(path.segment_count() == 2, "path should have 2 segments")
}

// Test 13: ImportPath to_string
fn test_import_path_to_string() {
    let mut path = ImportPath::new()
    path.add_segment("std")
    path.add_segment("vec")
    let s = path.to_string()
    assert(s.len() > 0, "path string should be non-empty")
}

// Test 14: Import creation
fn test_import_creation() {
    let path = ImportPath::new()
    let import = Import::new(path)
    assert(!import.is_glob, "import should not be glob initially")
}

// Test 15: Import set alias
fn test_import_alias() {
    let path = ImportPath::new()
    let mut import = Import::new(path)
    import.set_alias("io_utils")
    assert(import.alias == "io_utils", "alias should be set")
}

// Test 16: Import set glob
fn test_import_glob() {
    let path = ImportPath::new()
    let mut import = Import::new(path)
    import.set_glob()
    assert(import.is_glob, "import should be glob")
}

// Test 17: Import set pub
fn test_import_pub() {
    let path = ImportPath::new()
    let mut import = Import::new(path)
    import.set_pub()
    assert(import.is_pub, "import should be pub")
}

// Test 18: Import signature
fn test_import_signature() {
    let path = ImportPath::new()
    let mut import = Import::new(path)
    import.set_pub()
    let sig = import.signature()
    assert(sig.len() > 0, "signature should be non-empty")
}

// Test 19: ReExport creation
fn test_reexport_creation() {
    let reexport = ReExport::new("add")
    assert(reexport.original_name == "add", "original name should be set")
    assert(reexport.new_name == "add", "new name should match original initially")
}

// Test 20: ReExport with alias
fn test_reexport_alias() {
    let mut reexport = ReExport::new("add")
    reexport.with_alias("plus")
    assert(reexport.new_name == "plus", "new name should be aliased")
}

// Test 21: Crate creation
fn test_crate_creation() {
    let crate_obj = Crate::new("mylib", "1.0.0")
    assert(crate_obj.name == "mylib", "crate name should be set")
    assert(crate_obj.version == "1.0.0", "crate version should be set")
}

// Test 22: Crate add module
fn test_crate_add_module() {
    let mut crate_obj = Crate::new("mylib", "1.0.0")
    let module = Module::new("utils", "/utils")
    crate_obj.add_module(module)
    assert(crate_obj.module_count() == 1, "crate should have 1 module")
}

// Test 23: Crate add dependency
fn test_crate_add_dependency() {
    let mut crate_obj = Crate::new("mylib", "1.0.0")
    crate_obj.add_dependency("serde")
    assert(crate_obj.dependency_count() == 1, "crate should have 1 dependency")
}

// Test 24: Namespace creation
fn test_namespace_creation() {
    let ns = Namespace::new()
    assert(ns.symbol_count() == 0, "namespace should have 0 symbols initially")
}

// Test 25: Namespace define symbol
fn test_namespace_define() {
    let mut ns = Namespace::new()
    let success = ns.define("main")
    assert(success, "defining symbol should succeed")
    assert(ns.symbol_count() == 1, "namespace should have 1 symbol")
}

// Test 26: Namespace lookup symbol
fn test_namespace_lookup() {
    let mut ns = Namespace::new()
    ns.define("add")
    assert(ns.lookup("add"), "symbol should be found")
}

// Test 27: Prelude creation
fn test_prelude_creation() {
    let prelude = Prelude::new()
    assert(prelude.item_count() > 0, "prelude should have items")
}

// Test 28: Prelude has item
fn test_prelude_has_item() {
    let prelude = Prelude::new()
    assert(prelude.has_item("std::prelude::*"), "prelude should have std::prelude::*")
}

// Test 29: Complete module system creation
fn test_complete_module_system_creation() {
    let system = CompleteModuleSystem::new("myproject", "1.0.0")
    assert(true, "system creation should work")
}

// Test 30: Complete system stats
fn test_complete_system_stats() {
    let mut system = CompleteModuleSystem::new("myproject", "1.0.0")
    system.add_dependency("std")
    let stats = system.stats()
    assert(stats.len() > 0, "stats should be non-empty")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
