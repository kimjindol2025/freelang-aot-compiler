// Phase 15: Extended StdLib - 30개 무관용 테스트
// 표준 라이브러리 완전 검증

module test_extended_stdlib

use extended_stdlib::{
    Vec, HashMap, HashSet, VecIterator,
    File, FileMode, BufferedReader,
    StringUtils, CompleteStdLib
}

// ============ Vec Tests ============

// Test 1: Vec creation
fn test_vec_creation() {
    let v = Vec::new()
    assert(v.len() == 0, "new vec should be empty")
    assert(v.is_empty(), "vec should be empty")
}

// Test 2: Vec with capacity
fn test_vec_with_capacity() {
    let v = Vec::with_capacity(100)
    assert(v.capacity == 100, "capacity should be 100")
}

// Test 3: Vec push
fn test_vec_push() {
    let mut v = Vec::new()
    v.push("item1")
    assert(v.len() == 1, "vec should have 1 item")
    assert(!v.is_empty(), "vec should not be empty")
}

// Test 4: Vec get
fn test_vec_get() {
    let mut v = Vec::new()
    v.push("item1")
    let item = v.get(0)
    assert(item == "item1", "should get correct item")
}

// Test 5: Vec set
fn test_vec_set() {
    let mut v = Vec::new()
    v.push("item1")
    v.set(0, "item2")
    let item = v.get(0)
    assert(item == "item2", "should update item")
}

// Test 6: Vec contains
fn test_vec_contains() {
    let mut v = Vec::new()
    v.push("item1")
    assert(v.contains("item1"), "should contain item")
    assert(!v.contains("item2"), "should not contain missing item")
}

// Test 7: Vec clear
fn test_vec_clear() {
    let mut v = Vec::new()
    v.push("item1")
    v.clear()
    assert(v.len() == 0, "vec should be empty after clear")
}

// Test 8: Vec reverse
fn test_vec_reverse() {
    let mut v = Vec::new()
    v.push("a")
    v.push("b")
    v.push("c")
    v.reverse()
    assert(v.get(0) == "c", "first item should be c after reverse")
}

// ============ HashMap Tests ============

// Test 9: HashMap creation
fn test_hashmap_creation() {
    let m = HashMap::new()
    assert(m.len() == 0, "new hashmap should be empty")
    assert(m.is_empty(), "hashmap should be empty")
}

// Test 10: HashMap insert
fn test_hashmap_insert() {
    let mut m = HashMap::new()
    m.insert("key1", "value1")
    assert(m.len() == 1, "hashmap should have 1 entry")
}

// Test 11: HashMap get
fn test_hashmap_get() {
    let mut m = HashMap::new()
    m.insert("key1", "value1")
    let value = m.get("key1")
    assert(value == "value1", "should get correct value")
}

// Test 12: HashMap contains_key
fn test_hashmap_contains_key() {
    let mut m = HashMap::new()
    m.insert("key1", "value1")
    assert(m.contains_key("key1"), "should contain key")
}

// Test 13: HashMap remove
fn test_hashmap_remove() {
    let mut m = HashMap::new()
    m.insert("key1", "value1")
    m.remove("key1")
    assert(m.len() == 0, "hashmap should be empty after remove")
}

// Test 14: HashMap keys
fn test_hashmap_keys() {
    let mut m = HashMap::new()
    m.insert("key1", "value1")
    let keys = m.keys()
    assert(keys.len() == 1, "should have 1 key")
}

// Test 15: HashMap values
fn test_hashmap_values() {
    let mut m = HashMap::new()
    m.insert("key1", "value1")
    let values = m.values()
    assert(values.len() == 1, "should have 1 value")
}

// ============ HashSet Tests ============

// Test 16: HashSet creation
fn test_hashset_creation() {
    let s = HashSet::new()
    assert(s.len() == 0, "new hashset should be empty")
}

// Test 17: HashSet insert
fn test_hashset_insert() {
    let mut s = HashSet::new()
    let result = s.insert("item1")
    assert(result, "insert should succeed")
    assert(s.len() == 1, "hashset should have 1 item")
}

// Test 18: HashSet contains
fn test_hashset_contains() {
    let mut s = HashSet::new()
    s.insert("item1")
    assert(s.contains("item1"), "should contain item")
}

// Test 19: HashSet remove
fn test_hashset_remove() {
    let mut s = HashSet::new()
    s.insert("item1")
    s.remove("item1")
    assert(s.len() == 0, "hashset should be empty after remove")
}

// ============ Iterator Tests ============

// Test 20: VecIterator creation
fn test_vec_iterator_creation() {
    let v = Vec::new()
    let iter = VecIterator::new(v)
    assert(!iter.has_next(), "empty iterator should not have next")
}

// Test 21: VecIterator next
fn test_vec_iterator_next() {
    let mut v = Vec::new()
    v.push("item1")
    let mut iter = VecIterator::new(v)
    assert(iter.has_next(), "should have next")
    let item = iter.next()
    assert(item == "item1", "should get correct item")
}

// ============ File I/O Tests ============

// Test 22: File open
fn test_file_open() {
    let f = File::open("test.txt", FileMode::Read)
    assert(f.is_open, "file should be open")
}

// Test 23: File write
fn test_file_write() {
    let mut f = File::open("test.txt", FileMode::Write)
    let result = f.write("content")
    assert(result, "write should succeed")
}

// Test 24: File read
fn test_file_read() {
    let mut f = File::open("test.txt", FileMode::Read)
    f.content = "hello"
    let content = f.read()
    assert(content == "hello", "should read correct content")
}

// Test 25: File append
fn test_file_append() {
    let mut f = File::open("test.txt", FileMode::Append)
    f.content = "hello"
    f.append(" world")
    assert(f.content == "hello world", "should append content")
}

// Test 26: File close
fn test_file_close() {
    let mut f = File::open("test.txt", FileMode::Read)
    f.close()
    assert(!f.is_open, "file should be closed")
}

// ============ String Utils Tests ============

// Test 27: String split
fn test_string_split() {
    let parts = StringUtils::split("a,b,c", ",")
    assert(parts.len() == 3, "should split into 3 parts")
}

// Test 28: String join
fn test_string_join() {
    let parts = ["a", "b", "c"]
    let joined = StringUtils::join(parts, ",")
    assert(joined.len() > 0, "joined string should be non-empty")
}

// Test 29: String operations
fn test_string_starts_with() {
    assert(StringUtils::starts_with("hello", "he"), "should start with")
}

// Test 30: Complete StdLib system
fn test_complete_stdlib() {
    let mut lib = CompleteStdLib::new()
    let v = lib.create_vec()
    let m = lib.create_hashmap()
    let f = lib.create_file("test.txt", FileMode::Read)
    lib.string_operation()
    assert(lib.vec_count == 1, "should have created 1 vec")
    assert(lib.hashmap_count == 1, "should have created 1 hashmap")
    assert(lib.file_count == 1, "should have opened 1 file")
    assert(lib.string_ops == 1, "should have 1 string operation")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
