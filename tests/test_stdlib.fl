// Phase 10: Standard Library - Unforgiving Tests
// 20개 무관용 테스트: Memory, I/O, Math, String utilities

module test_stdlib

use stdlib::{Memory, Math, String, IO, Option}

// Test 1: Math abs function
fn test_math_abs_positive() {
    let result = Math::abs(42)
    assert(result == 42, "abs of positive number should be unchanged")
}

// Test 2: Math abs negative
fn test_math_abs_negative() {
    let result = Math::abs(-42)
    assert(result == 42, "abs of negative number should be positive")
}

// Test 3: Math abs zero
fn test_math_abs_zero() {
    let result = Math::abs(0)
    assert(result == 0, "abs of zero should be zero")
}

// Test 4: Math min function
fn test_math_min() {
    let result = Math::min(10, 20)
    assert(result == 10, "min should return smaller value")

    let result2 = Math::min(30, 5)
    assert(result2 == 5, "min should return smaller value")
}

// Test 5: Math min equal values
fn test_math_min_equal() {
    let result = Math::min(15, 15)
    assert(result == 15, "min of equal values should be that value")
}

// Test 6: Math max function
fn test_math_max() {
    let result = Math::max(10, 20)
    assert(result == 20, "max should return larger value")

    let result2 = Math::max(30, 5)
    assert(result2 == 30, "max should return larger value")
}

// Test 7: Math pi constant
fn test_math_pi() {
    let pi = Math::pi()
    assert(pi > 3.14 && pi < 3.15, "pi should be approximately 3.14159...")
}

// Test 8: Math e constant
fn test_math_e() {
    let e = Math::e()
    assert(e > 2.71 && e < 2.73, "e should be approximately 2.71828...")
}

// Test 9: Math sqrt function
fn test_math_sqrt() {
    let result = Math::sqrt(4.0)
    assert(result > 1.9 && result < 2.1, "sqrt(4) should be approximately 2")
}

// Test 10: Math sqrt precision
fn test_math_sqrt_precision() {
    let result = Math::sqrt(9.0)
    assert(result > 2.9 && result < 3.1, "sqrt(9) should be approximately 3")
}

// Test 11: String new creation
fn test_string_new() {
    let s = String::new()
    assert(s.length == 0, "new string should be empty")
    assert(s.capacity == 0, "new string capacity should be 0")
}

// Test 12: String length getter
fn test_string_length() {
    let s = String {
        data: [],
        length: 5,
        capacity: 10,
    }
    assert(s.length() == 5, "length() should return stored length")
}

// Test 13: Option Some variant
fn test_option_some() {
    let opt: Option<i64> = Option::Some(42)
    assert(opt.is_some(), "Some should return true for is_some()")
    assert(!opt.is_none(), "Some should return false for is_none()")
}

// Test 14: Option None variant
fn test_option_none() {
    let opt: Option<i64> = Option::None
    assert(!opt.is_some(), "None should return false for is_some()")
    assert(opt.is_none(), "None should return true for is_none()")
}

// Test 15: Option unwrap Some
fn test_option_unwrap_some() {
    let opt: Option<i64> = Option::Some(100)
    let value = opt.unwrap()
    assert(value == 100, "unwrap(Some) should return inner value")
}

// Test 16: String capacity allocation
fn test_string_capacity() {
    let s = String {
        data: [],
        length: 0,
        capacity: 16,
    }
    assert(s.capacity >= s.length, "capacity must be >= length")
}

// Test 17: Math min max consistency
fn test_math_min_max_consistency() {
    let min = Math::min(5, 15)
    let max = Math::max(5, 15)

    assert(min <= max, "min should be <= max")
    assert(min == 5 && max == 15, "min/max should be correctly ordered")
}

// Test 18: Math abs magnitude
fn test_math_abs_magnitude() {
    let a = Math::abs(-100)
    let b = Math::abs(100)

    assert(a == b, "abs should return same magnitude regardless of sign")
}

// Test 19: Option is_some and is_none mutual exclusivity
fn test_option_mutual_exclusivity() {
    let some_opt: Option<i64> = Option::Some(5)
    let none_opt: Option<i64> = Option::None

    // For any Option, is_some() XOR is_none() should be true
    assert((some_opt.is_some() && !some_opt.is_none()) ||
           (!some_opt.is_some() && some_opt.is_none()),
           "is_some and is_none must be mutually exclusive")

    assert((none_opt.is_some() && !none_opt.is_none()) ||
           (!none_opt.is_some() && none_opt.is_none()),
           "is_some and is_none must be mutually exclusive")
}

// Test 20: Math operations preserve types
fn test_math_type_preservation() {
    let a: i64 = 10
    let b: i64 = 20
    let min_result = Math::min(a, b)
    let max_result = Math::max(a, b)
    let abs_result = Math::abs(-30)

    // All results must be i64
    assert(min_result > 0, "min result must be valid")
    assert(max_result > 0, "max result must be valid")
    assert(abs_result > 0, "abs result must be valid")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
