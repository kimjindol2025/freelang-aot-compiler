// FreeLang Native AOT Compiler - Lexer Tests
// 10 Unforgiving tests for Phase 1: Parser

module test_lexer

use token::{Token, TokenType, TokenStream}
use lexer::Lexer

// Test 1: Integer literals
fn test_integer_literals() -> bool {
    let source = "let x = 42;"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Check token sequence
    let mut passed = true
    passed = passed && tokens.peek().type == TokenType::KW_let
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::IDENT
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::OP_assign
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::LIT_int
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::SEMICOLON

    return passed
}

// Test 2: Function declaration
fn test_function_declaration() -> bool {
    let source = "fn add(x: i32, y: i32) -> i32 { return x + y; }"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Check tokens: fn add ( x : i32 , y : i32 ) -> i32 { return x + y ; }
    let mut passed = true
    passed = passed && tokens.peek().type == TokenType::KW_fn
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::IDENT
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::LPAREN

    return passed
}

// Test 3: Binary operators
fn test_binary_operators() -> bool {
    let source = "a + b - c * d / e % f"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    let mut ops = []
    let mut token = tokens.peek()

    // Extract operators from token stream
    loop {
        if token.type == TokenType::OP_plus ||
           token.type == TokenType::OP_minus ||
           token.type == TokenType::OP_star ||
           token.type == TokenType::OP_slash ||
           token.type == TokenType::OP_percent {
            ops.push(token.type)
        }

        if token.type == TokenType::EOF {
            break
        }
        token = tokens.advance()
    }

    // Should have 5 operators
    return ops.len() == 5
}

// Test 4: Control flow keywords
fn test_control_flow() -> bool {
    let source = "if (true) { } else { } for x in y { } while (z) { }"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    let mut keywords = []
    let mut token = tokens.peek()

    loop {
        if token.type == TokenType::KW_if ||
           token.type == TokenType::KW_else ||
           token.type == TokenType::KW_for ||
           token.type == TokenType::KW_while {
            keywords.push(token.type)
        }

        if token.type == TokenType::EOF {
            break
        }
        token = tokens.advance()
    }

    // Should have 4 keywords
    return keywords.len() == 4
}

// Test 5: Struct definition
fn test_struct_definition() -> bool {
    let source = "struct Point { x: i32, y: i32 }"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Check: struct Point { x : i32 , y : i32 }
    let mut passed = true
    passed = passed && tokens.peek().type == TokenType::KW_struct
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::IDENT
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::LBRACE
    tokens.advance()

    // Count colons
    let mut colons = 0
    loop {
        if tokens.peek().type == TokenType::COLON {
            colons += 1
        }
        if tokens.peek().type == TokenType::EOF {
            break
        }
        tokens.advance()
    }

    return passed && colons == 2
}

// Test 6: Type annotations
fn test_type_annotations() -> bool {
    let source = "let x: u32 = 10; let y: f64 = 3.14; let z: string = \"hello\";"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Count colons (each variable has one)
    let mut colons = 0
    let mut token = tokens.peek()

    loop {
        if token.type == TokenType::COLON {
            colons += 1
        }
        if token.type == TokenType::EOF {
            break
        }
        token = tokens.advance()
    }

    return colons == 3
}

// Test 7: Error handling - unterminated string
fn test_unterminated_string() -> bool {
    let source = "let s = \"hello"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Should still tokenize the let and s, but might miss the string
    let mut passed = tokens.peek().type == TokenType::KW_let
    tokens.advance()
    passed = passed && tokens.peek().type == TokenType::IDENT

    return passed
}

// Test 8: Comments
fn test_comments() -> bool {
    let source = "let x = 1; // comment\nlet y = 2; /* block comment */ let z = 3;"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Count let keywords (should be 3)
    let mut lets = 0
    let mut token = tokens.peek()

    loop {
        if token.type == TokenType::KW_let {
            lets += 1
        }
        if token.type == TokenType::EOF {
            break
        }
        token = tokens.advance()
    }

    return lets == 3
}

// Test 9: Operator precedence tokens
fn test_operator_precedence() -> bool {
    let source = "a == b && c || d && e < f"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Should correctly tokenize ==, &&, ||, <
    let mut ops = []
    let mut token = tokens.peek()

    loop {
        if token.type == TokenType::OP_eq ||
           token.type == TokenType::OP_and ||
           token.type == TokenType::OP_or ||
           token.type == TokenType::OP_lt {
            ops.push(token.type)
        }
        if token.type == TokenType::EOF {
            break
        }
        token = tokens.advance()
    }

    return ops.len() == 4
}

// Test 10: Nested expressions
fn test_nested_expressions() -> bool {
    let source = "((x + (y * z)) - (a / b))"
    let mut lexer = Lexer::new(source)
    let tokens = lexer.tokenize()

    // Count parentheses
    let mut lparen = 0
    let mut rparen = 0
    let mut token = tokens.peek()

    loop {
        if token.type == TokenType::LPAREN {
            lparen += 1
        } else if token.type == TokenType::RPAREN {
            rparen += 1
        }
        if token.type == TokenType::EOF {
            break
        }
        token = tokens.advance()
    }

    return lparen == 5 && rparen == 5
}

// Main test runner
fn main() -> i32 {
    let mut passed = 0
    let mut total = 10

    if test_integer_literals() {
        passed += 1
        println("✓ Test 1: Integer literals")
    } else {
        println("✗ Test 1: Integer literals")
    }

    if test_function_declaration() {
        passed += 1
        println("✓ Test 2: Function declaration")
    } else {
        println("✗ Test 2: Function declaration")
    }

    if test_binary_operators() {
        passed += 1
        println("✓ Test 3: Binary operators")
    } else {
        println("✗ Test 3: Binary operators")
    }

    if test_control_flow() {
        passed += 1
        println("✓ Test 4: Control flow")
    } else {
        println("✗ Test 4: Control flow")
    }

    if test_struct_definition() {
        passed += 1
        println("✓ Test 5: Struct definition")
    } else {
        println("✗ Test 5: Struct definition")
    }

    if test_type_annotations() {
        passed += 1
        println("✓ Test 6: Type annotations")
    } else {
        println("✗ Test 6: Type annotations")
    }

    if test_unterminated_string() {
        passed += 1
        println("✓ Test 7: Unterminated string handling")
    } else {
        println("✗ Test 7: Unterminated string handling")
    }

    if test_comments() {
        passed += 1
        println("✓ Test 8: Comments")
    } else {
        println("✗ Test 8: Comments")
    }

    if test_operator_precedence() {
        passed += 1
        println("✓ Test 9: Operator precedence")
    } else {
        println("✗ Test 9: Operator precedence")
    }

    if test_nested_expressions() {
        passed += 1
        println("✓ Test 10: Nested expressions")
    } else {
        println("✗ Test 10: Nested expressions")
    }

    println("")
    println("Tests passed: " + passed.to_string() + "/" + total.to_string())

    return if passed == total { 0 } else { 1 }
}
