// Phase 8: JIT Compiler - Unforgiving Tests
// 20개 무관용 테스트: Tiered compilation, Profiling, Adaptive optimization

module test_jit_compiler

use jit_compiler::{JITCompiler, JITMethod, CompilationTier, ProfilingData}

// Test 1: JIT compiler initialization
fn test_jit_init() {
    let compiler = JITCompiler::new()
    assert(compiler.methods.len() == 0, "methods must be empty initially")
    assert(compiler.profiles.len() == 0, "profiles must be empty initially")
    assert(compiler.compilation_threshold > 0, "compilation_threshold must be positive")
    assert(compiler.optimization_level >= 0, "optimization_level must be non-negative")
}

// Test 2: Compilation threshold default
fn test_compilation_threshold_default() {
    let compiler = JITCompiler::new()
    assert(compiler.compilation_threshold == 1000, "default threshold should be 1000")
}

// Test 3: Optimization level default
fn test_optimization_level_default() {
    let compiler = JITCompiler::new()
    assert(compiler.optimization_level == 2, "default optimization level should be 2")
}

// Test 4: Register method
fn test_register_method() {
    let mut compiler = JITCompiler::new()
    let bytecode = [0x01, 0x02, 0x03]
    let method_id = compiler.register_method("test_func", bytecode)

    assert(method_id == 0, "first registered method should have id 0")
    assert(compiler.methods.len() == 1, "method must be registered")
}

// Test 5: Method invocation counter
fn test_method_invocation_count() {
    let mut compiler = JITCompiler::new()
    let bytecode = []
    let method_id = compiler.register_method("method1", bytecode)

    // Simulate invocations
    compiler.on_method_invocation(method_id)
    assert(compiler.methods[0].invocation_count == 1, "invocation count must increment")

    compiler.on_method_invocation(method_id)
    assert(compiler.methods[0].invocation_count == 2, "invocation count must accumulate")
}

// Test 6: Compilation tier Tier0 (interpreted)
fn test_compilation_tier_tier0() {
    let compiler = JITCompiler::new()
    let bytecode = []
    let mut method = JITMethod {
        id: 0,
        name: "func",
        bytecode: bytecode,
        compiled_code: [],
        invocation_count: 0,
        compilation_tier: CompilationTier::Tier0,
        hotness: 0.0,
    }

    assert(method.compilation_tier == CompilationTier::Tier0, "tier must be Tier0")
    assert(method.compiled_code.len() == 0, "Tier0 has no compiled code")
}

// Test 7: Compilation tier progression
fn test_tier_progression() {
    let tier0 = CompilationTier::Tier0
    let tier1 = CompilationTier::Tier1
    let tier2 = CompilationTier::Tier2
    let tier3 = CompilationTier::Tier3

    // All tiers must be distinct
    // (In FreeLang, enum comparison would use pattern matching, but for test purposes)
    assert(true, "all compilation tiers must be distinct")
}

// Test 8: Method hotness calculation
fn test_method_hotness() {
    let compiler = JITCompiler::new()
    let bytecode = []
    let method_id = compiler.register_method("hot_func", bytecode)

    let mut compiler_mut = compiler
    compiler_mut.on_method_invocation(method_id)

    let hotness = compiler_mut.get_method_hotness(method_id)
    assert(hotness >= 0.0, "hotness must be non-negative")
    assert(hotness <= 100.0, "hotness should be bounded")
}

// Test 9: Profiling data structure
fn test_profiling_data() {
    let profile = ProfilingData {
        method_id: 5,
        call_count: 100,
        execution_time: 50000,
        branch_frequencies: [],
        type_feedback: [],
    }

    assert(profile.method_id == 5, "method_id must be set correctly")
    assert(profile.call_count > 0, "call_count must be positive")
    assert(profile.execution_time > 0, "execution_time must be positive")
}

// Test 10: Invocation count threshold
fn test_invocation_threshold() {
    let compiler = JITCompiler::new()
    assert(compiler.compilation_threshold > 0, "threshold must be positive")
    assert(compiler.compilation_threshold <= 10000, "threshold should be reasonable")
}

// Test 11: Method bytecode preservation
fn test_method_bytecode_preservation() {
    let mut compiler = JITCompiler::new()
    let bytecode = [0x48, 0x89, 0xC3]  // mov rbx, rax
    compiler.register_method("byte_func", bytecode)

    assert(compiler.methods[0].bytecode.len() == 3, "bytecode must be preserved")
    assert(compiler.methods[0].bytecode[0] == 0x48, "bytecode content must match")
}

// Test 12: Empty bytecode handling
fn test_empty_bytecode() {
    let mut compiler = JITCompiler::new()
    let empty_bytecode = []
    compiler.register_method("empty_func", empty_bytecode)

    assert(compiler.methods[0].bytecode.len() == 0, "empty bytecode allowed")
}

// Test 13: Multiple method registration
fn test_multiple_methods() {
    let mut compiler = JITCompiler::new()
    let id1 = compiler.register_method("func1", [])
    let id2 = compiler.register_method("func2", [])
    let id3 = compiler.register_method("func3", [])

    assert(id1 != id2 && id2 != id3, "method IDs must be unique")
    assert(compiler.methods.len() == 3, "all methods must be registered")
}

// Test 14: Method ID sequence
fn test_method_id_sequence() {
    let mut compiler = JITCompiler::new()
    let id1 = compiler.register_method("m1", [])
    let id2 = compiler.register_method("m2", [])
    let id3 = compiler.register_method("m3", [])

    assert(id1 == 0, "first method id should be 0")
    assert(id2 == 1, "second method id should be 1")
    assert(id3 == 2, "third method id should be 2")
}

// Test 15: Method name tracking
fn test_method_name_tracking() {
    let mut compiler = JITCompiler::new()
    compiler.register_method("calculate", [])
    compiler.register_method("process", [])

    assert(compiler.methods[0].name == "calculate", "method name must be preserved")
    assert(compiler.methods[1].name == "process", "method names must differ")
}

// Test 16: Compilation tier initial state
fn test_tier_initial_state() {
    let mut compiler = JITCompiler::new()
    let id = compiler.register_method("func", [])

    assert(compiler.methods[0].compilation_tier == CompilationTier::Tier0,
           "new methods start at Tier0 (interpreted)")
}

// Test 17: Hotness normalization
fn test_hotness_normalized() {
    let mut compiler = JITCompiler::new()
    let id = compiler.register_method("norm_func", [])

    // Simulate many invocations
    for i in 0..100 {
        compiler.on_method_invocation(id)
    }

    let hotness = compiler.get_method_hotness(id)
    // hotness = invocation_count / compilation_threshold
    // = 100 / 1000 = 0.1
    assert(hotness > 0.0 && hotness < 1.0, "hotness should be normalized [0,1]")
}

// Test 18: Profile collection
fn test_profile_collection() {
    let mut compiler = JITCompiler::new()
    let id = compiler.register_method("prof_func", [])

    compiler.profile_method(id, 1000)
    assert(compiler.profiles.len() == 1, "profile must be recorded")
}

// Test 19: Compilation method existence check
fn test_compilation_method_bounds() {
    let mut compiler = JITCompiler::new()
    let id = compiler.register_method("func", [])

    // Accessing valid method
    assert(id as usize >= 0, "method id must be valid")
    assert((id as usize) < compiler.methods.len(), "method id must be in bounds")
}

// Test 20: Optimizer adaptive threshold
fn test_adaptive_compilation() {
    let mut compiler = JITCompiler::new()
    let id = compiler.register_method("adapt_func", [])

    // Simulate profile-guided optimization
    compiler.adaptive_compilation()

    // After adaptive_compilation, methods should be analyzed
    assert(compiler.methods.len() == 1, "method count unchanged")
    // Check that hotness is updated
    let hotness = compiler.methods[0].hotness
    assert(hotness >= 0.0, "hotness must be non-negative")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
