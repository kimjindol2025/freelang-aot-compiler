        println("✗ Test 4: Add instruction")
    }

    if test_mov_instruction() {
        passed += 1
        println("✓ Test 5: Mov instruction")
    } else {
        println("✗ Test 5: Mov instruction")
    }

    if test_label_creation() {
        passed += 1
        println("✓ Test 6: Label creation")
    } else {
        println("✗ Test 6: Label creation")
    }

    if test_jump_instruction() {
        passed += 1
        println("✓ Test 7: Jump instruction")
    } else {
        println("✗ Test 7: Jump instruction")
    }

    if test_return_instruction() {
        passed += 1
        println("✓ Test 8: Return instruction")
    } else {
        println("✗ Test 8: Return instruction")
    }

    if test_basic_block_creation() {
        passed += 1
        println("✓ Test 9: Basic block creation")
    } else {
        println("✗ Test 9: Basic block creation")
    }

    if test_function_creation() {
        passed += 1
        println("✓ Test 10: Function creation")
    } else {
        println("✗ Test 10: Function creation")
    }

    if test_program_creation() {
        passed += 1
        println("✓ Test 11: Program creation")
    } else {
        println("✗ Test 11: Program creation")
    }

    if test_register_allocator_gp() {
        passed += 1
        println("✓ Test 12: Register allocator")
    } else {
        println("✗ Test 12: Register allocator")
    }

    if test_optimizer_constant_folding() {
        passed += 1
        println("✓ Test 13: Constant folding")
    } else {
        println("✗ Test 13: Constant folding")
    }

    if test_optimizer_dead_code() {
        passed += 1
        println("✓ Test 14: Dead code elimination")
    } else {
        println("✗ Test 14: Dead code elimination")
    }

    if test_optimizer_level_o3() {
        passed += 1
        println("✓ Test 15: Optimization levels")
    } else {
        println("✗ Test 15: Optimization levels")
    }

    println("")
    println("Tests passed: " + passed.to_string() + "/" + total.to_string())

    return if passed == total { 0 } else { 1 }
}
