// FreeLang Native AOT Compiler - Code Generation Tests
// 15 Unforgiving tests for Phase 2: Code Generation

module test_codegen

use ir::{Operand, Register, IRInstruction, IRFunction, BasicBlock, IRProgram}
use codegen::CodeGen
use optimizer::{Optimizer, OptLevel}

// Test 1: Immediate operand generation
fn test_immediate_operand() -> bool {
    let op = Operand::imm(42)
    return match op {
        Operand::Immediate(v) => v == 42,
        _ => false,
    }
}

// Test 2: Register operand generation
fn test_register_operand() -> bool {
    let op = Operand::reg(Register::RAX)
    return match op {
        Operand::Register(Register::RAX) => true,
        _ => false,
    }
}

// Test 3: Memory operand generation
fn test_memory_operand() -> bool {
    let op = Operand::mem(Register::RBP, -8)
    return match op {
        Operand::Memory { base, offset } => {
            base == Register::RBP && offset == -8
        },
        _ => false,
    }
}

// Test 4: Add instruction generation
fn test_add_instruction() -> bool {
    let instr = IRInstruction::add(
        Operand::reg(Register::RAX),
        Operand::imm(5),
        Operand::imm(3)
    )

    return match instr {
        IRInstruction::Add { dest: _, src1: _, src2: _ } => true,
        _ => false,
    }
}

// Test 5: Mov instruction generation
fn test_mov_instruction() -> bool {
    let instr = IRInstruction::mov(
        Operand::reg(Register::RAX),
        Operand::imm(100)
    )

    return match instr {
        IRInstruction::Mov { dest: _, src: _ } => true,
        _ => false,
    }
}

// Test 6: Label creation
fn test_label_creation() -> bool {
    let instr = IRInstruction::label("loop_start")

    return match instr {
        IRInstruction::Label { name } => name == "loop_start",
        _ => false,
    }
}

// Test 7: Jump instruction
fn test_jump_instruction() -> bool {
    let instr = IRInstruction::jmp("end")

    return match instr {
        IRInstruction::Jmp { label } => label == "end",
        _ => false,
    }
}

// Test 8: Return instruction
fn test_return_instruction() -> bool {
    let instr = IRInstruction::ret(Some(Operand::reg(Register::RAX)))

    return match instr {
        IRInstruction::Ret { value: Some(_) } => true,
        _ => false,
    }
}

// Test 9: Basic block creation
fn test_basic_block_creation() -> bool {
    let mut block = BasicBlock::new("entry")
    block.add_instruction(IRInstruction::label("entry"))
    block.add_instruction(IRInstruction::mov(
        Operand::reg(Register::RAX),
        Operand::imm(0)
    ))

    return block.instruction_count() == 3 // 2 instructions + 1 terminator
}

// Test 10: Function creation
fn test_function_creation() -> bool {
    let func = IRFunction::new(
        "main",
        [],
        "i32"
    )

    return func.name == "main" && func.params.len() == 0
}

// Test 11: Program creation
fn test_program_creation() -> bool {
    let mut program = IRProgram::new()
    let func = IRFunction::new("main", [], "i32")
    program.add_function(func)

    return program.function_count() == 1
}

// Test 12: Register allocator - allocate GP register
fn test_register_allocator_gp() -> bool {
    let mut alloc = RegisterAllocator::new()
    let reg = alloc.allocate_gp()

    return match reg {
        Some(Register::RDI) => true,
        _ => false,
    }
}

// Test 13: Optimizer - constant folding
fn test_optimizer_constant_folding() -> bool {
    let mut opt = Optimizer::new(OptLevel::O1)

    // Create program with: 5 + 3 = 8
    let mut program = IRProgram::new()
    let mut func = IRFunction::new("test", [], "i32")
    let mut block = BasicBlock::new("entry")

    block.add_instruction(IRInstruction::Add {
        dest: Operand::reg(Register::RAX),
        src1: Operand::imm(5),
        src2: Operand::imm(3),
    })
    block.set_terminator(IRInstruction::ret(Some(Operand::reg(Register::RAX))))

    func.add_block(block)
    program.add_function(func)

    let before = program.total_instructions()
    let optimized = opt.optimize(program)
    let after = optimized.total_instructions()

    return before >= after // Should optimize or maintain
}

// Test 14: Optimizer - dead code elimination
fn test_optimizer_dead_code() -> bool {
    let mut opt = Optimizer::new(OptLevel::O2)

    let mut program = IRProgram::new()
    let mut func = IRFunction::new("test", [], "i32")
    let mut block = BasicBlock::new("entry")

    // Dead move
    block.add_instruction(IRInstruction::mov(
        Operand::reg(Register::RBX),
        Operand::imm(100)
    ))
    // Used instruction
    block.add_instruction(IRInstruction::ret(Some(Operand::reg(Register::RAX))))
    block.set_terminator(IRInstruction::ret(Some(Operand::reg(Register::RAX))))

    func.add_block(block)
    program.add_function(func)

    let optimized = opt.optimize(program)
    let stats = opt.get_stats()

    return stats.dead_code_removed > 0
}

// Test 15: Optimization levels - O3 includes vectorization
fn test_optimizer_level_o3() -> bool {
    let opt_o0 = Optimizer::new(OptLevel::O0)
    let opt_o3 = Optimizer::new(OptLevel::O3)

    // Both should have proper level assignment
    return match (opt_o0.level, opt_o3.level) {
        (OptLevel::O0, OptLevel::O3) => true,
        _ => false,
    }
}

// Register allocator structure (imported from codegen)
struct RegisterAllocator {
    gp_regs: Register[],
    gp_available: bool[],
    xmm_regs: Register[],
    xmm_available: bool[],
}

impl RegisterAllocator {
    fn new() -> RegisterAllocator {
        let mut gp = []
        gp.push(Register::RDI)
        gp.push(Register::RSI)
        gp.push(Register::RDX)
        gp.push(Register::RCX)
        gp.push(Register::R8)
        gp.push(Register::R9)
        gp.push(Register::R10)
        gp.push(Register::R11)

        let mut xmm = []
        xmm.push(Register::XMM0)
        xmm.push(Register::XMM1)
        xmm.push(Register::XMM2)
        xmm.push(Register::XMM3)
        xmm.push(Register::XMM4)
        xmm.push(Register::XMM5)
        xmm.push(Register::XMM6)
        xmm.push(Register::XMM7)

        return RegisterAllocator {
            gp_regs: gp,
            gp_available: [true, true, true, true, true, true, true, true],
            xmm_regs: xmm,
            xmm_available: [true, true, true, true, true, true, true, true],
        }
    }

    fn allocate_gp(&mut self) -> Option<Register> {
        for i in 0..8 {
            if self.gp_available[i] {
                self.gp_available[i] = false
                return Some(self.gp_regs[i])
            }
        }
        return None
    }
}

// Option helper
enum Option<T> {
    Some(value: T),
    None,
}

impl Option<T> {
    fn is_some(&self) -> bool {
        return match self {
            Some(_) => true,
            None => false,
        }
    }
}

// Main test runner
