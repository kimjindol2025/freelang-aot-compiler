// Phase 17: Procedural Macros - 28개 무관용 테스트
// 매크로 시스템 완전 검증

module test_procedural_macros

use procedural_macros::{
    Token, TokenType, TokenStream,
    MacroInvocation, MacroDefinition, MacroExpander,
    BuiltinMacros, DeriveMacro, AttributeMacro,
    FunctionLikeMacro, CompleteMacroSystem
}

// Test 1: Token creation
fn test_token_creation() {
    let ty = TokenType::Keyword("fn")
    let token = Token::new(ty, "test.fl:10:1")
    assert(token.span == "test.fl:10:1", "token span should be set")
}

// Test 2: TokenStream creation
fn test_tokenstream_creation() {
    let stream = TokenStream::new()
    assert(stream.is_empty(), "tokenstream should be empty initially")
    assert(stream.count() == 0, "tokenstream should have 0 tokens")
}

// Test 3: Add token to stream
fn test_add_token_to_stream() {
    let mut stream = TokenStream::new()
    let token = Token::new(TokenType::Keyword("fn"), "test.fl:1:1")
    stream.add_token(token)
    assert(stream.count() == 1, "tokenstream should have 1 token")
}

// Test 4: TokenStream to string
fn test_tokenstream_to_string() {
    let mut stream = TokenStream::new()
    stream.add_token(Token::new(TokenType::Keyword("fn"), "test.fl:1:1"))
    let s = stream.to_string()
    assert(s.len() > 0, "tokenstream string should be non-empty")
}

// Test 5: Macro invocation creation
fn test_macro_invocation_creation() {
    let stream = TokenStream::new()
    let invocation = MacroInvocation::new("vec", stream)
    assert(invocation.name == "vec", "macro name should be vec")
}

// Test 6: Macro definition creation
fn test_macro_definition_creation() {
    let def = MacroDefinition::new("vec")
    assert(def.name == "vec", "macro name should be vec")
    assert(def.rule_count() == 0, "should have 0 rules initially")
}

// Test 7: Add rule to macro
fn test_add_rule_to_macro() {
    let mut def = MacroDefinition::new("assert")
    def.add_rule("($cond:expr)", "if !$cond { panic(...) }")
    assert(def.rule_count() == 1, "should have 1 rule")
}

// Test 8: Mark macro as builtin
fn test_mark_builtin() {
    let mut def = MacroDefinition::new("println")
    def.mark_builtin()
    assert(def.is_builtin, "macro should be marked as builtin")
}

// Test 9: Macro expander creation
fn test_macro_expander_creation() {
    let expander = MacroExpander::new()
    assert(!expander.has_errors(), "should have no errors initially")
}

// Test 10: Register macro
fn test_register_macro() {
    let mut expander = MacroExpander::new()
    let def = MacroDefinition::new("custom")
    expander.register_macro(def)
    assert(expander.definitions.len() == 1, "should have 1 macro")
}

// Test 11: Lookup macro
fn test_lookup_macro() {
    let mut expander = MacroExpander::new()
    let def = MacroDefinition::new("test_macro")
    expander.register_macro(def)
    let found = expander.lookup_macro("test_macro")
    assert(found.name == "test_macro", "should find macro")
}

// Test 12: Lookup missing macro
fn test_lookup_missing_macro() {
    let expander = MacroExpander::new()
    let found = expander.lookup_macro("nonexistent")
    assert(found.name.len() == 0, "should not find missing macro")
}

// Test 13: Builtin vec! macro
fn test_builtin_vec_macro() {
    let elements = ["1", "2", "3"]
    let code = BuiltinMacros::vec_macro(elements)
    assert(code.len() > 0, "vec! should generate code")
}

// Test 14: Builtin println! macro
fn test_builtin_println_macro() {
    let code = BuiltinMacros::println_macro("hello")
    assert(code.len() > 0, "println! should generate code")
}

// Test 15: Builtin assert! macro
fn test_builtin_assert_macro() {
    let code = BuiltinMacros::assert_macro("x > 0", "x must be positive")
    assert(code.len() > 0, "assert! should generate code")
}

// Test 16: Builtin dbg! macro
fn test_builtin_dbg_macro() {
    let code = BuiltinMacros::dbg_macro("x")
    assert(code.len() > 0, "dbg! should generate code")
}

// Test 17: Derive Debug
fn test_derive_debug() {
    let mut derive = DeriveMacro::new("Debug", "MyStruct")
    derive.derive_debug()
    let code = derive.get_code()
    assert(code.len() > 0, "should generate Debug implementation")
}

// Test 18: Derive Clone
fn test_derive_clone() {
    let mut derive = DeriveMacro::new("Clone", "MyStruct")
    derive.derive_clone()
    let code = derive.get_code()
    assert(code.len() > 0, "should generate Clone implementation")
}

// Test 19: Derive Default
fn test_derive_default() {
    let mut derive = DeriveMacro::new("Default", "MyStruct")
    derive.derive_default()
    let code = derive.get_code()
    assert(code.len() > 0, "should generate Default implementation")
}

// Test 20: Derive PartialEq
fn test_derive_partial_eq() {
    let mut derive = DeriveMacro::new("PartialEq", "MyStruct")
    derive.derive_partial_eq()
    let code = derive.get_code()
    assert(code.len() > 0, "should generate PartialEq implementation")
}

// Test 21: Attribute test
fn test_attribute_test() {
    let mut attr = AttributeMacro::new("test", "fn")
    attr.test_attribute("test_fn")
    let code = attr.code
    assert(code.len() > 0, "should generate test attribute code")
}

// Test 22: Attribute inline
fn test_attribute_inline() {
    let mut attr = AttributeMacro::new("inline", "fn")
    attr.inline_attribute("fast_fn")
    let code = attr.code
    assert(code.len() > 0, "should generate inline attribute code")
}

// Test 23: Attribute deprecated
fn test_attribute_deprecated() {
    let mut attr = AttributeMacro::new("deprecated", "fn")
    attr.deprecated_attribute("old_fn")
    let code = attr.code
    assert(code.len() > 0, "should generate deprecated attribute code")
}

// Test 24: Function-like macro creation
fn test_function_like_macro_creation() {
    let macro_ = FunctionLikeMacro::new("add_one")
    assert(macro_.name == "add_one", "macro name should be set")
}

// Test 25: Function-like macro invocation
fn test_function_like_macro_invoke() {
    let mut macro_ = FunctionLikeMacro::new("inc")
    macro_.set_body("x + 1", 1)
    let args = ["5"]
    let result = macro_.invoke(args)
    assert(result.len() > 0, "macro invocation should produce result")
}

// Test 26: Complete macro system creation
fn test_complete_macro_system() {
    let system = CompleteMacroSystem::new()
    assert(system.expander.definitions.len() == 0, "should have 0 macros initially")
}

// Test 27: Register macro in system
fn test_register_in_system() {
    let mut system = CompleteMacroSystem::new()
    let def = MacroDefinition::new("custom_macro")
    system.register_macro(def)
    assert(system.expander.definitions.len() == 1, "should have 1 macro")
}

// Test 28: Complete system statistics
fn test_system_statistics() {
    let mut system = CompleteMacroSystem::new()
    let def = MacroDefinition::new("test")
    system.register_macro(def)
    let mut derive = DeriveMacro::new("Debug", "Struct")
    system.add_derive_macro(derive)
    let stats = system.stats()
    assert(stats.len() > 0, "stats should be non-empty")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
