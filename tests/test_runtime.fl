// FreeLang Native AOT Compiler - Runtime Tests
// 5 Unforgiving tests for Phase 4: Runtime

module test_runtime

use runtime_support::{MemoryManager, StandardIO, ErrorHandler, RuntimeInit}

// Test 1: Memory manager initialization
fn test_memory_manager_init() -> bool {
    let manager = MemoryManager::new()

    return manager.heap_start == 0x602000 &&
           manager.heap_end == 0x602000 &&
           manager.heap_current == 0x602000
}

// Test 2: Memory allocation
fn test_memory_allocation() -> bool {
    let mut manager = MemoryManager::new()
    let ptr = manager.allocate(1024)

    return match ptr {
        Some(p) => {
            p == 0x602000 &&
            manager.heap_current == 0x602400 &&
            manager.heap_size() == 1024
        },
        None => false,
    }
}

// Test 3: Multiple allocations
fn test_multiple_allocations() -> bool {
    let mut manager = MemoryManager::new()
    let ptr1 = manager.allocate(512)
    let ptr2 = manager.allocate(512)

    return match (ptr1, ptr2) {
        (Some(p1), Some(p2)) => {
            p1 == 0x602000 &&
            p2 == 0x602200 &&
            manager.heap_size() == 1024
        },
        _ => false,
    }
}

// Test 4: Error handler
fn test_error_handler() -> bool {
    let mut handler = ErrorHandler::new()

    return handler.get_error() == 0 &&
           handler.last_error == 0
}

// Test 5: Error reporting
fn test_error_reporting() -> bool {
    let mut handler = ErrorHandler::new()
    handler.set_error(12) // Out of memory

    let msg = handler.error_message(12)

    return msg == "Out of memory" && handler.get_error() == 12
}

// Option helper
enum Option<T> {
    Some(value: T),
    None,
}

impl Option<T> {
    fn is_none(&self) -> bool {
        return match self {
            None => true,
            Some(_) => false,
        }
    }
}

// Main test runner
fn main() -> i32 {
    let mut passed = 0
    let mut total = 5

    if test_memory_manager_init() {
        passed += 1
        println("✓ Test 1: Memory manager init")
    } else {
        println("✗ Test 1: Memory manager init")
    }

    if test_memory_allocation() {
        passed += 1
        println("✓ Test 2: Memory allocation")
    } else {
        println("✗ Test 2: Memory allocation")
    }

    if test_multiple_allocations() {
        passed += 1
        println("✓ Test 3: Multiple allocations")
    } else {
        println("✗ Test 3: Multiple allocations")
    }

    if test_error_handler() {
        passed += 1
        println("✓ Test 4: Error handler")
    } else {
        println("✗ Test 4: Error handler")
    }

    if test_error_reporting() {
        passed += 1
        println("✓ Test 5: Error reporting")
    } else {
        println("✗ Test 5: Error reporting")
    }

    println("")
    println("Tests passed: " + passed.to_string() + "/" + total.to_string())

    return if passed == total { 0 } else { 1 }
}
