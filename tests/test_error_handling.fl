// Phase 14: Result & Error Handling - 22개 무관용 테스트
// 에러 처리 완전 검증

module test_error_handling

use error_handling::{
    ErrorKind, Error, Result, Option,
    TryContext, TryBlock, ErrorChain,
    ErrorPolicy, SafeExecutor,
    CompleteErrorHandlingSystem
}

// Test 1: Error kind message
fn test_error_kind_message() {
    let io_err = ErrorKind::IoError("file not found")
    let msg = io_err.message()
    assert(msg.len() > 0, "error message should be non-empty")
}

// Test 2: Error kind code
fn test_error_kind_code() {
    let type_err = ErrorKind::TypeError("type mismatch")
    let code = type_err.code()
    assert(code == "E002", "type error code should be E002")
}

// Test 3: Error creation
fn test_error_creation() {
    let err = Error::new(ErrorKind::ValueError("invalid value"), "test.fl:10")
    assert(err.source == "test.fl:10", "error source should be set")
}

// Test 4: Error with context
fn test_error_with_context() {
    let mut err = Error::new(ErrorKind::RuntimeError("runtime error"), "test.fl:20")
    err.with_context("during parsing")
    assert(err.context == "during parsing", "context should be set")
}

// Test 5: Result::Ok
fn test_result_ok() {
    let result = Result::Ok("success")
    assert(result.is_ok(), "Result should be Ok")
    assert(!result.is_err(), "Result should not be Err")
}

// Test 6: Result::Err
fn test_result_err() {
    let err = Error::new(ErrorKind::ValueError("test"), "test.fl:1")
    let result = Result::Err(err)
    assert(!result.is_ok(), "Result should not be Ok")
    assert(result.is_err(), "Result should be Err")
}

// Test 7: Result unwrap
fn test_result_unwrap() {
    let result = Result::Ok("value")
    let value = result.unwrap()
    assert(value == "value", "unwrap should return the value")
}

// Test 8: Result unwrap_or
fn test_result_unwrap_or() {
    let err = Error::new(ErrorKind::ValueError("error"), "test.fl:1")
    let result = Result::Err(err)
    let value = result.unwrap_or("default")
    assert(value == "default", "unwrap_or should return default on error")
}

// Test 9: Option::Some
fn test_option_some() {
    let opt = Option::Some("value")
    assert(opt.is_some(), "Option should be Some")
    assert(!opt.is_none(), "Option should not be None")
}

// Test 10: Option::None
fn test_option_none() {
    let opt = Option::None
    assert(!opt.is_some(), "Option should not be Some")
    assert(opt.is_none(), "Option should be None")
}

// Test 11: Option unwrap_or
fn test_option_unwrap_or() {
    let opt = Option::None
    let value = opt.unwrap_or("default")
    assert(value == "default", "unwrap_or should return default on None")
}

// Test 12: Option to_result
fn test_option_to_result() {
    let opt = Option::Some("value")
    let err = Error::new(ErrorKind::ValueError("error"), "test.fl:1")
    let result = opt.to_result(err)
    assert(result.is_ok(), "to_result should convert Some to Ok")
}

// Test 13: Try context initialization
fn test_try_context_init() {
    let ctx = TryContext::new()
    assert(!ctx.has_error(), "should not have error initially")
}

// Test 14: Try context unwrap success
fn test_try_context_unwrap_success() {
    let mut ctx = TryContext::new()
    let result = Result::Ok("value")
    let value = ctx.try_unwrap(result)
    assert(value == "value", "should unwrap successfully")
    assert(!ctx.has_error(), "should not have error after successful unwrap")
}

// Test 15: Try context unwrap error
fn test_try_context_unwrap_error() {
    let mut ctx = TryContext::new()
    let err = Error::new(ErrorKind::ValueError("error"), "test.fl:1")
    let result = Result::Err(err)
    ctx.try_unwrap(result)
    assert(ctx.has_error(), "should have error after failed unwrap")
    assert(ctx.error_count() == 1, "should have 1 error")
}

// Test 16: Try block execution
fn test_try_block_execution() {
    let mut block = TryBlock::new()
    let result = Result::Ok("value")
    let success = block.execute(result)
    assert(success, "try block should execute successfully")
    assert(block.success, "block should be marked as success")
}

// Test 17: Error chain
fn test_error_chain() {
    let mut chain = ErrorChain::new()
    let err1 = Error::new(ErrorKind::ValueError("error 1"), "test.fl:1")
    let err2 = Error::new(ErrorKind::TypeError("error 2"), "test.fl:2")
    chain.add_error(err1)
    chain.add_error(err2)
    assert(chain.len() == 2, "should have 2 errors in chain")
}

// Test 18: Safe executor with panic policy
fn test_safe_executor_panic() {
    let mut executor = SafeExecutor::new(ErrorPolicy::Panic)
    let result = Result::Ok("value")
    let exec_result = executor.execute(result)
    assert(exec_result.is_ok(), "execution should succeed")
}

// Test 19: Safe executor recovery
fn test_safe_executor_recovery() {
    let mut executor = SafeExecutor::new(ErrorPolicy::Recover("recovered"))
    let err = Error::new(ErrorKind::RuntimeError("error"), "test.fl:1")
    let result = Result::Err(err)
    let exec_result = executor.execute(result)
    assert(exec_result.is_ok(), "should recover with default value")
}

// Test 20: Safe executor success rate
fn test_safe_executor_success_rate() {
    let mut executor = SafeExecutor::new(ErrorPolicy::Recover("recovered"))
    let ok_result = Result::Ok("value")
    executor.execute(ok_result)
    executor.execute(ok_result)
    let rate = executor.success_rate()
    assert(rate == 100.0, "success rate should be 100%")
}

// Test 21: Complete error handling system
fn test_complete_error_handling_system() {
    let mut system = CompleteErrorHandlingSystem::new()
    let err = system.create_error(ErrorKind::ValueError("test error"), "test.fl:1")
    assert(system.error_chain.len() == 1, "should have 1 error in chain")
}

// Test 22: System statistics
fn test_system_statistics() {
    let mut system = CompleteErrorHandlingSystem::new()
    system.create_error(ErrorKind::ValueError("error"), "test.fl:1")
    let stats = system.stats()
    assert(stats.len() > 0, "stats should be non-empty")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
