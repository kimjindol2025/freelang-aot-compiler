// FreeLang Native AOT Compiler - Linker Tests
// 10 Unforgiving tests for Phase 3: Linker

module test_linker

use elf_builder::{ELFBuilder, Section}
use relocation::{Relocator, SymbolRef, Relocation, RelocationType}
use section_manager::{SectionManager, SectionDescriptor}

// Test 1: ELF Header creation
fn test_elf_header_creation() -> bool {
    let builder = ELFBuilder::new()

    return builder.header.e_ident[0] == 0x7F &&
           builder.header.e_ident[1] == 'E' as u8 &&
           builder.header.e_type == 2 &&
           builder.header.e_machine == 0x3E
}

// Test 2: Section creation
fn test_section_creation() -> bool {
    let section = Section::new(".text", 1) // SHT_PROGBITS = 1

    return section.name == ".text" &&
           section.section_type == 1 &&
           section.flags == 0x6 // SHF_ALLOC | SHF_EXECINSTR
}

// Test 3: Add section to builder
fn test_add_section_to_builder() -> bool {
    let mut builder = ELFBuilder::new()
    let section = Section::new(".text", 1)
    builder.add_section(section)

    return builder.sections.len() == 1
}

// Test 4: Symbol addition
fn test_symbol_addition() -> bool {
    let mut builder = ELFBuilder::new()
    let sym_idx = builder.add_symbol("main", 0x400000, 1)

    return sym_idx == 0 &&
           builder.symbols.len() == 1
}

// Test 5: Relocator creation
fn test_relocator_creation() -> bool {
    let relocator = Relocator::new(0x400000)

    return relocator.base_address == 0x400000 &&
           relocator.reloc_table.symbol_count() == 0 &&
           relocator.reloc_table.relocation_count() == 0
}

// Test 6: Symbol reference addition
fn test_symbol_ref_addition() -> bool {
    let mut relocator = Relocator::new(0x400000)
    let sym = SymbolRef {
        name: "printf",
        value: 0x401000,
        size: 100,
        section_index: 1,
        is_defined: true,
    }

    let idx = relocator.add_symbol(sym)

    return idx == 0 &&
           relocator.reloc_table.symbol_count() == 1
}

// Test 7: Section manager creation
fn test_section_manager_creation() -> bool {
    let manager = SectionManager::new()

    return manager.section_count() == 0 &&
           manager.current_text_addr == 0x400000 &&
           manager.current_data_addr == 0x601000
}

// Test 8: Add section to manager
fn test_section_manager_add() -> bool {
    let mut manager = SectionManager::new()
    let mut section = SectionDescriptor::new(".text", "PROGBITS")
    section.size = 4096
    section.flags = 0x6 // ALLOC | EXECINSTR
    section.align = 4096

    manager.add_section(section)

    return manager.section_count() == 1
}

// Test 9: Relocation verification
fn test_relocation_verification() -> bool {
    let mut relocator = Relocator::new(0x400000)
    let sym = SymbolRef {
        name: "test",
        value: 0x400100,
        size: 10,
        section_index: 1,
        is_defined: true,
    }

    relocator.add_symbol(sym)

    let result = relocator.reloc_table.verify_relocations()

    return match result {
        Ok(()) => true,
        Err(_) => false,
    }
}

// Test 10: Memory layout verification
fn test_memory_layout_verification() -> bool {
    let mut manager = SectionManager::new()

    let mut text = SectionDescriptor::new(".text", "PROGBITS")
    text.size = 0x1000
    text.flags = 0x6
    text.align = 0x1000

    let mut data = SectionDescriptor::new(".data", "PROGBITS")
    data.size = 0x1000
    data.flags = 0x3 // ALLOC | WRITE
    data.align = 8

    manager.add_section(text)
    manager.add_section(data)

    let result = manager.verify_layout()

    return match result {
        Ok(()) => true,
        Err(_) => false,
    }
}

// Helper: Result type
enum Result<T, E> {
    Ok(value: T),
    Err(error: E),
}

impl Result<T, E> {
    fn is_ok(&self) -> bool {
        return match self {
            Ok(_) => true,
            Err(_) => false,
        }
    }
}

// Main test runner
fn main() -> i32 {
    let mut passed = 0
    let mut total = 10

    if test_elf_header_creation() {
        passed += 1
        println("✓ Test 1: ELF header creation")
    } else {
        println("✗ Test 1: ELF header creation")
    }

    if test_section_creation() {
        passed += 1
        println("✓ Test 2: Section creation")
    } else {
        println("✗ Test 2: Section creation")
    }

    if test_add_section_to_builder() {
        passed += 1
        println("✓ Test 3: Add section to builder")
    } else {
        println("✗ Test 3: Add section to builder")
    }

    if test_symbol_addition() {
        passed += 1
        println("✓ Test 4: Symbol addition")
    } else {
        println("✗ Test 4: Symbol addition")
    }

    if test_relocator_creation() {
        passed += 1
        println("✓ Test 5: Relocator creation")
    } else {
        println("✗ Test 5: Relocator creation")
    }

    if test_symbol_ref_addition() {
        passed += 1
        println("✓ Test 6: Symbol ref addition")
    } else {
        println("✗ Test 6: Symbol ref addition")
    }

    if test_section_manager_creation() {
        passed += 1
        println("✓ Test 7: Section manager creation")
    } else {
        println("✗ Test 7: Section manager creation")
    }

    if test_section_manager_add() {
        passed += 1
        println("✓ Test 8: Section manager add")
    } else {
        println("✗ Test 8: Section manager add")
    }

    if test_relocation_verification() {
        passed += 1
        println("✓ Test 9: Relocation verification")
    } else {
        println("✗ Test 9: Relocation verification")
    }

    if test_memory_layout_verification() {
        passed += 1
        println("✓ Test 10: Memory layout verification")
    } else {
        println("✗ Test 10: Memory layout verification")
    }

    println("")
    println("Tests passed: " + passed.to_string() + "/" + total.to_string())

    return if passed == total { 0 } else { 1 }
}
