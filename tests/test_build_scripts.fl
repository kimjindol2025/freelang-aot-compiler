// Phase 24: Build Scripts - 32개 무관용 테스트
// 빌드 시스템 및 빌드 자동화 검증

module test_build_scripts

use build_scripts::{
    Manifest, BuildScript, BuildPhase, BuildStage,
    Dependency, LinkConfig, BuildEnv, BuildOutput,
    RebuildCondition, CustomCommand, TargetConfig,
    BuildContext, CompleteBuildSystem
}

// Test 1: Manifest creation
fn test_manifest_creation() {
    let manifest = Manifest::new("mylib", "1.0.0")
    assert(manifest.name == "mylib", "name should be set")
    assert(manifest.version == "1.0.0", "version should be set")
}

// Test 2: Manifest add author
fn test_manifest_add_author() {
    let mut manifest = Manifest::new("proj", "0.1.0")
    manifest.add_author("Alice")
    assert(manifest.authors.len() == 1, "should have 1 author")
}

// Test 3: Manifest add dependency
fn test_manifest_add_dependency() {
    let mut manifest = Manifest::new("app", "1.0.0")
    manifest.add_dependency("serde")
    assert(manifest.dependency_count() == 1, "should have 1 dependency")
}

// Test 4: Manifest add dev dependency
fn test_manifest_add_dev_dependency() {
    let mut manifest = Manifest::new("lib", "1.0.0")
    manifest.add_dev_dependency("criterion")
    assert(manifest.dev_dependencies.len() == 1, "should have 1 dev dependency")
}

// Test 5: Manifest set build script
fn test_manifest_set_build_script() {
    let mut manifest = Manifest::new("complex", "1.0.0")
    manifest.set_build_script("build.rs")
    assert(manifest.has_build_script(), "should have build script")
}

// Test 6: BuildScript creation
fn test_build_script_creation() {
    let script = BuildScript::new("build")
    assert(!script.executed, "should not be executed initially")
}

// Test 7: BuildScript set code
fn test_build_script_set_code() {
    let mut script = BuildScript::new("compile")
    script.set_code("println!(\"Building...\")")
    assert(script.code.len() > 0, "code should be set")
}

// Test 8: BuildScript execute
fn test_build_script_execute() {
    let mut script = BuildScript::new("test")
    script.execute()
    assert(script.is_executed(), "should be executed")
}

// Test 9: BuildStage creation
fn test_build_stage_creation() {
    let stage = BuildStage::new(BuildPhase::PreBuild)
    assert(stage.status == "pending", "status should be pending")
}

// Test 10: BuildStage start
fn test_build_stage_start() {
    let mut stage = BuildStage::new(BuildPhase::CompileLib)
    stage.start()
    assert(stage.status == "running", "status should be running")
}

// Test 11: BuildStage complete
fn test_build_stage_complete() {
    let mut stage = BuildStage::new(BuildPhase::RunTests)
    stage.start()
    stage.complete()
    assert(stage.is_completed(), "should be completed")
}

// Test 12: Dependency creation
fn test_dependency_creation() {
    let dep = Dependency::new("serde", "1.0")
    assert(dep.name == "serde", "name should be set")
}

// Test 13: Dependency add feature
fn test_dependency_add_feature() {
    let mut dep = Dependency::new("tokio", "1.0")
    dep.add_feature("full")
    assert(dep.feature_count() == 1, "should have 1 feature")
}

// Test 14: Dependency set optional
fn test_dependency_optional() {
    let mut dep = Dependency::new("custom", "0.5")
    dep.set_optional()
    assert(dep.optional, "should be optional")
}

// Test 15: LinkConfig creation
fn test_link_config_creation() {
    let config = LinkConfig::new("mylib")
    assert(config.name == "mylib", "name should be set")
}

// Test 16: LinkConfig set link type
fn test_link_config_type() {
    let mut config = LinkConfig::new("openssl")
    config.set_link_type("dylib")
    assert(config.link_type == "dylib", "link type should be dylib")
}

// Test 17: LinkConfig add search path
fn test_link_config_search_path() {
    let mut config = LinkConfig::new("ssl")
    config.add_search_path("/usr/lib")
    assert(config.search_paths.len() == 1, "should have 1 search path")
}

// Test 18: LinkConfig add lib
fn test_link_config_add_lib() {
    let mut config = LinkConfig::new("crypto")
    config.add_lib("libcrypto.a")
    assert(config.lib_count() == 1, "should have 1 lib")
}

// Test 19: BuildEnv creation
fn test_build_env_creation() {
    let env = BuildEnv::new()
    assert(env.var_count() == 0, "should have 0 vars initially")
}

// Test 20: BuildEnv set var
fn test_build_env_set_var() {
    let mut env = BuildEnv::new()
    env.set_var("CC", "gcc")
    assert(env.var_count() == 1, "should have 1 var")
}

// Test 21: BuildEnv get var
fn test_build_env_get_var() {
    let mut env = BuildEnv::new()
    env.set_var("TARGET", "x86_64")
    let val = env.get_var("TARGET")
    assert(val == "x86_64", "should get target value")
}

// Test 22: BuildOutput creation
fn test_build_output_creation() {
    let output = BuildOutput::new()
    assert(output.message_count() == 0, "should have 0 messages")
    assert(output.error_count() == 0, "should have 0 errors")
}

// Test 23: BuildOutput add message
fn test_build_output_message() {
    let mut output = BuildOutput::new()
    output.add_message("compilation started")
    assert(output.message_count() == 1, "should have 1 message")
}

// Test 24: BuildOutput add error
fn test_build_output_error() {
    let mut output = BuildOutput::new()
    output.add_error("type mismatch")
    assert(output.error_count() == 1, "should have 1 error")
    assert(!output.success(), "should not be successful")
}

// Test 25: RebuildCondition creation
fn test_rebuild_condition_creation() {
    let cond = RebuildCondition::new("src/lib.rs", "changed")
    assert(cond.file_path == "src/lib.rs", "file path should be set")
}

// Test 26: RebuildCondition should rebuild
fn test_rebuild_condition_check() {
    let cond = RebuildCondition::new("config.toml", "always")
    assert(cond.should_rebuild(), "should rebuild for always condition")
}

// Test 27: CustomCommand creation
fn test_custom_command_creation() {
    let cmd = CustomCommand::new("gcc")
    assert(cmd.program == "gcc", "program should be set")
}

// Test 28: CustomCommand add arg
fn test_custom_command_arg() {
    let mut cmd = CustomCommand::new("clang")
    cmd.add_arg("-O2")
    assert(cmd.arg_count() == 1, "should have 1 arg")
}

// Test 29: TargetConfig creation
fn test_target_config_creation() {
    let target = TargetConfig::new("mybin", "bin")
    assert(target.is_binary(), "should be binary target")
}

// Test 30: Complete build system
fn test_complete_build_system() {
    let mut system = CompleteBuildSystem::new("app", "2.0.0")
    let stats = system.stats()
    assert(stats.len() > 0, "stats should be non-empty")
}

// Test 31: Build system add dependency
fn test_build_system_add_dep() {
    let mut system = CompleteBuildSystem::new("proj", "1.0.0")
    let dep = Dependency::new("num", "0.4")
    system.add_dependency(dep)
    assert(system.dependencies.len() == 1, "should have 1 dependency")
}

// Test 32: Build system execute
fn test_build_system_execute() {
    let mut system = CompleteBuildSystem::new("build", "1.0.0")
    let success = system.execute_build()
    assert(success, "build should succeed")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
