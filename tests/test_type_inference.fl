// Phase 13: Full Type Inference - 18개 무관용 테스트
// Hindley-Milner 타입 추론 완전 검증

module test_type_inference

use type_inference::{
    TypeVar, Type, TypeEnvironment, Substitution, ConstraintSet,
    Unifier, InferenceResult, HindleyMilnerInferencer,
    TypeScheme, PolymorphicEnvironment, CompleteTypeInferenceSystem
}

// Test 1: Type environment initialization
fn test_type_environment_init() {
    let env = TypeEnvironment::new()
    assert(env.bindings.len() == 0, "should have 0 bindings initially")
}

// Test 2: Add type binding
fn test_add_binding() {
    let mut env = TypeEnvironment::new()
    env.add_binding("x", "i64")
    assert(env.bindings.len() == 1, "should have 1 binding")
}

// Test 3: Lookup binding
fn test_lookup_binding() {
    let mut env = TypeEnvironment::new()
    env.add_binding("x", "i64")
    let binding = env.lookup("x")
    assert(binding.len() > 0, "should find binding")
}

// Test 4: Fresh type variable
fn test_fresh_type_var() {
    let mut env = TypeEnvironment::new()
    let var1 = env.fresh_type_var("t1")
    let var2 = env.fresh_type_var("t2")
    assert(var1.id != var2.id, "should create different type variables")
    assert(env.type_vars.len() == 2, "should have 2 type vars")
}

// Test 5: Substitution creation
fn test_substitution_create() {
    let subst = Substitution::new()
    assert(subst.mappings.len() == 0, "should have 0 mappings initially")
}

// Test 6: Add substitution mapping
fn test_add_substitution() {
    let mut subst = Substitution::new()
    subst.add("'a", "i64")
    assert(subst.mappings.len() == 1, "should have 1 mapping")
}

// Test 7: Apply substitution
fn test_apply_substitution() {
    let mut subst = Substitution::new()
    subst.add("'a", "i64")
    let result = subst.apply("'a")
    assert(result == "i64", "substitution should apply correctly")
}

// Test 8: Constraint set
fn test_constraint_set() {
    let mut cs = ConstraintSet::new()
    cs.add_equality("t1", "i64")
    assert(cs.count() == 1, "should have 1 constraint")
}

// Test 9: Unifier initialization
fn test_unifier_init() {
    let unifier = Unifier::new()
    assert(unifier.errors.len() == 0, "should have 0 errors initially")
    assert(unifier.is_success(), "should be successful initially")
}

// Test 10: Unify type variables
fn test_unify_type_vars() {
    let mut unifier = Unifier::new()
    let success = unifier.unify("'a", "i64")
    assert(success, "unification should succeed")
    assert(unifier.is_success(), "unifier should be in success state")
}

// Test 11: Hindley-Milner inferencer initialization
fn test_hm_inferencer_init() {
    let inferencer = HindleyMilnerInferencer::new()
    assert(inferencer.var_counter == 0, "var counter should start at 0")
}

// Test 12: Infer constant type
fn test_infer_const() {
    let mut inferencer = HindleyMilnerInferencer::new()
    let bool_type = inferencer.infer_const("true")
    assert(bool_type == "bool", "true should infer to bool")
    let int_type = inferencer.infer_const("42")
    assert(int_type == "i64", "42 should infer to i64")
    let float_type = inferencer.infer_const("3.14")
    assert(float_type == "f64", "3.14 should infer to f64")
}

// Test 13: Infer binary operation
fn test_infer_binop() {
    let mut inferencer = HindleyMilnerInferencer::new()
    let result = inferencer.infer_binop("+", "i64", "i64")
    assert(result == "i64", "i64 + i64 should be i64")
    let cmp_result = inferencer.infer_binop("==", "i64", "i64")
    assert(cmp_result == "bool", "comparison should return bool")
}

// Test 14: Lambda type inference
fn test_infer_lambda() {
    let mut inferencer = HindleyMilnerInferencer::new()
    let lambda_type = inferencer.infer_lambda("x", "i64", "i64")
    assert(lambda_type == "i64 -> i64", "lambda should have correct type")
}

// Test 15: Type scheme
fn test_type_scheme() {
    let mut scheme = TypeScheme::new("'a -> 'a")
    scheme.add_quantified_var("'a")
    let s = scheme.as_string()
    assert(s.len() > 0, "scheme string should be non-empty")
}

// Test 16: Polymorphic environment
fn test_polymorphic_environment() {
    let mut env = PolymorphicEnvironment::new()
    let scheme = TypeScheme::new("'a -> 'a")
    env.add_binding("identity", scheme)
    assert(env.count() == 1, "should have 1 binding")
}

// Test 17: Complete type inference system
fn test_complete_type_inference_system() {
    let mut system = CompleteTypeInferenceSystem::new()
    system.infer_and_record("x", "i64")
    system.infer_and_record("y", "f64")
    assert(system.result_count() == 2, "should have 2 inferred types")
}

// Test 18: Type inference statistics
fn test_inference_stats() {
    let mut system = CompleteTypeInferenceSystem::new()
    system.infer_and_record("x", "i64")
    let stats = system.stats()
    assert(stats.len() > 0, "stats should be non-empty")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
