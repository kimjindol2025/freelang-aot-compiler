// Phase 21: Trait Objects - 32개 무관용 테스트
// 트레이트 객체 및 동적 디스패치 검증

module test_trait_objects

use trait_objects::{
    TraitMethod, TraitDefinition,
    VTableEntry, VTable, TypeInfo,
    TraitObject, DynamicDispatcher,
    TypeEraser, Downcaster, ObjectMetadata,
    MultiTraitObject, TraitObjectConstraint,
    ObjectSafetyChecker, TraitObjectRegistry,
    CompleteTraitObjectSystem
}

// Test 1: TraitMethod creation
fn test_trait_method_creation() {
    let method = TraitMethod::new("draw", "fn draw(&self)")
    assert(method.name == "draw", "method name should be set")
}

// Test 2: TraitMethod object safety
fn test_trait_method_safety() {
    let mut method = TraitMethod::new("render", "fn render(&self) -> Result")
    method.check_object_safety()
    assert(method.is_object_safe, "method should be object-safe")
}

// Test 3: TraitDefinition creation
fn test_trait_definition_creation() {
    let trait_def = TraitDefinition::new("Draw")
    assert(trait_def.name == "Draw", "trait name should be set")
    assert(trait_def.method_count() == 0, "should have 0 methods initially")
}

// Test 4: TraitDefinition add method
fn test_trait_definition_add_method() {
    let mut trait_def = TraitDefinition::new("Shape")
    let method = TraitMethod::new("area", "fn area(&self) -> f64")
    trait_def.add_method(method)
    assert(trait_def.method_count() == 1, "should have 1 method")
}

// Test 5: TraitDefinition object safety validation
fn test_trait_definition_validate() {
    let mut trait_def = TraitDefinition::new("Widget")
    let method = TraitMethod::new("render", "fn render(&self)")
    trait_def.add_method(method)
    let is_safe = trait_def.validate_object_safety()
    assert(is_safe, "trait should be object-safe")
}

// Test 6: VTableEntry creation
fn test_vtable_entry_creation() {
    let entry = VTableEntry::new("draw", "0x12345678")
    assert(entry.method_name == "draw", "method name should be set")
}

// Test 7: VTable creation
fn test_vtable_creation() {
    let vtable = VTable::new("Shape")
    assert(vtable.trait_name == "Shape", "trait name should be set")
    assert(vtable.entry_count() == 0, "should have 0 entries initially")
}

// Test 8: VTable add entry
fn test_vtable_add_entry() {
    let mut vtable = VTable::new("Draw")
    let entry = VTableEntry::new("draw", "0xABCD")
    vtable.add_entry(entry)
    assert(vtable.entry_count() == 1, "should have 1 entry")
}

// Test 9: VTable lookup
fn test_vtable_lookup() {
    let mut vtable = VTable::new("Widget")
    let entry = VTableEntry::new("render", "0x9999")
    vtable.add_entry(entry)
    let ptr = vtable.lookup("render")
    assert(ptr == "0x9999", "should find method pointer")
}

// Test 10: TypeInfo creation
fn test_type_info_creation() {
    let info = TypeInfo::new("Circle", 24)
    assert(info.type_name == "Circle", "type name should be set")
    assert(info.size == 24, "size should be set")
}

// Test 11: TypeInfo set alignment
fn test_type_info_alignment() {
    let mut info = TypeInfo::new("Square", 16)
    info.set_alignment(8)
    assert(info.alignment == 8, "alignment should be set")
}

// Test 12: TypeInfo set drop function
fn test_type_info_drop_fn() {
    let mut info = TypeInfo::new("Resource", 32)
    info.set_drop_fn("drop_resource")
    assert(info.drop_fn == "drop_resource", "drop function should be set")
}

// Test 13: TraitObject creation
fn test_trait_object_creation() {
    let info = TypeInfo::new("Circle", 24)
    let obj = TraitObject::new("0x1000", "0x2000", info)
    assert(obj.data_ptr == "0x1000", "data pointer should be set")
}

// Test 14: TraitObject call method
fn test_trait_object_call_method() {
    let info = TypeInfo::new("Shape", 16)
    let obj = TraitObject::new("0x5000", "0x6000", info)
    let result = obj.call_method("draw")
    assert(result.len() > 0, "method call should return result")
}

// Test 15: TraitObject get type name
fn test_trait_object_type_name() {
    let info = TypeInfo::new("Widget", 32)
    let obj = TraitObject::new("0x3000", "0x4000", info)
    let name = obj.get_type_name()
    assert(name == "Widget", "type name should be retrieved")
}

// Test 16: TraitObject get size
fn test_trait_object_size() {
    let info = TypeInfo::new("Button", 48)
    let obj = TraitObject::new("0x7000", "0x8000", info)
    let size = obj.get_size()
    assert(size == 48, "size should be retrieved")
}

// Test 17: DynamicDispatcher creation
fn test_dynamic_dispatcher_creation() {
    let info = TypeInfo::new("Drawable", 64)
    let obj = TraitObject::new("0xA000", "0xB000", info)
    let dispatcher = DynamicDispatcher::new(obj)
    assert(dispatcher.call_count() == 0, "should have 0 calls initially")
}

// Test 18: DynamicDispatcher dispatch
fn test_dynamic_dispatcher_dispatch() {
    let info = TypeInfo::new("Painter", 56)
    let obj = TraitObject::new("0xC000", "0xD000", info)
    let mut dispatcher = DynamicDispatcher::new(obj)
    dispatcher.dispatch("paint")
    assert(dispatcher.call_count() == 1, "should have 1 call after dispatch")
}

// Test 19: TypeEraser creation
fn test_type_eraser_creation() {
    let eraser = TypeEraser::new("Circle", "Shape")
    assert(eraser.trait_name == "Shape", "trait name should be set")
}

// Test 20: TypeEraser erase type
fn test_type_eraser_erase() {
    let mut eraser = TypeEraser::new("Triangle", "Shape")
    let success = eraser.erase_type()
    assert(success, "type erasure should succeed")
}

// Test 21: TypeEraser get erased
fn test_type_eraser_get_erased() {
    let mut eraser = TypeEraser::new("Rect", "Shape")
    eraser.erase_type()
    let erased = eraser.get_erased()
    assert(erased.len() > 0, "erased type should be non-empty")
}

// Test 22: Downcaster creation
fn test_downcaster_creation() {
    let downcaster = Downcaster::new("Shape")
    assert(downcaster.trait_name == "Shape", "trait name should be set")
}

// Test 23: Downcaster downcast to
fn test_downcaster_downcast() {
    let mut downcaster = Downcaster::new("Widget")
    downcaster.downcast_to("Button")
    assert(downcaster.target_type == "Button", "target type should be set")
}

// Test 24: Downcaster is valid downcast
fn test_downcaster_valid() {
    let mut downcaster = Downcaster::new("Shape")
    downcaster.downcast_to("Circle")
    let valid = downcaster.is_valid_downcast("Circle")
    assert(valid, "downcast should be valid")
}

// Test 25: ObjectMetadata creation
fn test_object_metadata_creation() {
    let meta = ObjectMetadata::new("Draw", "Circle")
    assert(meta.trait_name == "Draw", "trait name should be set")
}

// Test 26: ObjectMetadata set vtable size
fn test_object_metadata_vtable_size() {
    let mut meta = ObjectMetadata::new("Shape", "Square")
    meta.set_vtable_size(5)
    assert(meta.vtable_size == 5, "vtable size should be set")
}

// Test 27: ObjectMetadata signature
fn test_object_metadata_signature() {
    let meta = ObjectMetadata::new("Drawable", "Triangle")
    let sig = meta.signature()
    assert(sig.len() > 0, "signature should be non-empty")
}

// Test 28: MultiTraitObject creation
fn test_multi_trait_object_creation() {
    let multi = MultiTraitObject::new("0xF000")
    assert(multi.trait_count() == 0, "should have 0 traits initially")
}

// Test 29: MultiTraitObject add trait
fn test_multi_trait_object_add_trait() {
    let mut multi = MultiTraitObject::new("0x10000")
    multi.add_trait("Draw", "0x11000")
    multi.add_trait("Clone", "0x12000")
    assert(multi.trait_count() == 2, "should have 2 traits")
}

// Test 30: MultiTraitObject has trait
fn test_multi_trait_object_has_trait() {
    let mut multi = MultiTraitObject::new("0x13000")
    multi.add_trait("Shape", "0x14000")
    assert(multi.has_trait("Shape"), "should have Shape trait")
}

// Test 31: ObjectSafetyChecker creation
fn test_object_safety_checker_creation() {
    let checker = ObjectSafetyChecker::new("Draw")
    assert(checker.violation_count() == 0, "should have 0 violations initially")
}

// Test 32: Complete trait object system
fn test_complete_trait_object_system() {
    let mut system = CompleteTraitObjectSystem::new()
    let trait_def = TraitDefinition::new("Drawable")
    system.add_trait(trait_def)
    let stats = system.stats()
    assert(stats.len() > 0, "stats should be non-empty")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
