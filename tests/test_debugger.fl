// Phase 9: Debugger - Unforgiving Tests
// 20개 무관용 테스트: DWARF, Breakpoints, Stack traces

module test_debugger

use debugger::{Debugger, Breakpoint, DebugInfoGenerator, DIE, DIETag, LineTable, LineInfo}

// Test 1: Debugger initialization
fn test_debugger_init() {
    let debugger = Debugger::new()
    assert(debugger.breakpoints.len() == 0, "breakpoints must be empty initially")
    assert(debugger.next_breakpoint_id == 1, "breakpoint ID counter starts at 1")
    assert(debugger.call_stack.len() == 0, "call stack must be empty")
}

// Test 2: Breakpoint creation
fn test_breakpoint_new() {
    let bp = Breakpoint::new(1, 0x400000)
    assert(bp.id == 1, "breakpoint id must match")
    assert(bp.address == 0x400000, "breakpoint address must match")
    assert(bp.enabled == true, "breakpoint enabled by default")
    assert(bp.hit_count == 0, "breakpoint hit_count starts at 0")
}

// Test 3: Set breakpoint
fn test_set_breakpoint() {
    let mut debugger = Debugger::new()
    let bp_id = debugger.set_breakpoint(0x401000)

    assert(bp_id == 1, "first breakpoint should have id 1")
    assert(debugger.breakpoints.len() == 1, "breakpoint must be added")
}

// Test 4: Multiple breakpoints
fn test_multiple_breakpoints() {
    let mut debugger = Debugger::new()
    let id1 = debugger.set_breakpoint(0x400000)
    let id2 = debugger.set_breakpoint(0x401000)
    let id3 = debugger.set_breakpoint(0x402000)

    assert(id1 != id2 && id2 != id3, "breakpoint ids must be unique")
    assert(debugger.breakpoints.len() == 3, "all breakpoints must be registered")
}

// Test 5: Breakpoint ID increment
fn test_breakpoint_id_increment() {
    let mut debugger = Debugger::new()
    let id1 = debugger.set_breakpoint(0x400000)
    let id2 = debugger.set_breakpoint(0x401000)

    assert(id2 == id1 + 1, "breakpoint IDs must increment")
}

// Test 6: Remove breakpoint
fn test_remove_breakpoint() {
    let mut debugger = Debugger::new()
    let id1 = debugger.set_breakpoint(0x400000)
    let id2 = debugger.set_breakpoint(0x401000)

    assert(debugger.breakpoints.len() == 2, "two breakpoints set")

    debugger.remove_breakpoint(id1)
    assert(debugger.breakpoints.len() == 1, "breakpoint removed")
}

// Test 7: Check breakpoint hit
fn test_check_breakpoint_hit() {
    let mut debugger = Debugger::new()
    let bp_id = debugger.set_breakpoint(0x400000)

    let hit = debugger.check_breakpoint(0x400000)
    assert(hit.is_some(), "breakpoint must be hit at address")
}

// Test 8: Breakpoint hit count
fn test_breakpoint_hit_count() {
    let mut debugger = Debugger::new()
    let bp_id = debugger.set_breakpoint(0x400000)

    // Simulate multiple hits
    debugger.check_breakpoint(0x400000)
    debugger.check_breakpoint(0x400000)

    assert(debugger.breakpoints[0].hit_count == 2, "hit_count must increment")
}

// Test 9: Push call frame
fn test_push_frame() {
    let mut debugger = Debugger::new()
    assert(debugger.call_stack.len() == 0, "stack empty initially")

    debugger.push_frame("main", 0x400000)
    assert(debugger.call_stack.len() == 1, "frame must be pushed")
    assert(debugger.call_stack[0].function_name == "main", "function name must match")
}

// Test 10: Pop call frame
fn test_pop_frame() {
    let mut debugger = Debugger::new()
    debugger.push_frame("func1", 0x400000)
    debugger.push_frame("func2", 0x401000)

    assert(debugger.call_stack.len() == 2, "two frames on stack")

    debugger.pop_frame()
    assert(debugger.call_stack.len() == 1, "frame must be popped")
}

// Test 11: Call stack depth
fn test_call_stack_depth() {
    let mut debugger = Debugger::new()
    for i in 0..5 {
        debugger.push_frame("func", 0x400000 + (i as u64 * 0x1000))
    }

    assert(debugger.call_stack.len() == 5, "stack depth must be 5")
}

// Test 12: Debug info generator init
fn test_debug_info_generator_init() {
    let gen = DebugInfoGenerator::new()
    assert(gen.dies.len() == 0, "DIEs empty initially")
    assert(gen.line_table.files.len() == 0, "files empty initially")
    assert(gen.line_table.directories.len() == 0, "directories empty initially")
}

// Test 13: Add compile unit
fn test_add_compile_unit() {
    let mut gen = DebugInfoGenerator::new()
    let offset = gen.add_compile_unit("main.fl", "freelang-compiler")

    assert(offset == 0, "first compile unit offset is 0")
    assert(gen.dies.len() == 1, "DIE must be added")
}

// Test 14: Add subprogram
fn test_add_subprogram() {
    let mut gen = DebugInfoGenerator::new()
    gen.add_compile_unit("main.fl", "freelang-compiler")
    let offset = gen.add_subprogram("main", 0x400000)

    assert(offset == 1, "subprogram offset increments")
    assert(gen.dies.len() == 2, "second DIE added")
}

// Test 15: Add variable
fn test_add_variable() {
    let mut gen = DebugInfoGenerator::new()
    gen.add_compile_unit("main.fl", "freelang-compiler")
    gen.add_variable("count", "i64", 0x7ffffffde000)

    assert(gen.dies.len() == 2, "variable DIE added")
}

// Test 16: Add line info
fn test_add_line_info() {
    let mut gen = DebugInfoGenerator::new()
    gen.add_line_info(0x400000, "main.fl", 10, 5)

    assert(gen.line_table.line_info.len() == 1, "line info recorded")
    assert(gen.line_table.files.len() == 1, "file added to table")
}

// Test 17: DIE tag enumeration
fn test_die_tag_types() {
    let tags = [
        DIETag::CompileUnit,
        DIETag::SubProgram,
        DIETag::Variable,
        DIETag::Parameter,
        DIETag::Type,
    ]

    assert(tags.len() == 5, "multiple DIE tag types available")
}

// Test 18: Line table file tracking
fn test_line_table_files() {
    let mut gen = DebugInfoGenerator::new()
    gen.add_line_info(0x400000, "file1.fl", 1, 1)
    gen.add_line_info(0x400001, "file2.fl", 2, 1)

    assert(gen.line_table.files.len() == 2, "multiple files tracked")
}

// Test 19: Return address tracking
fn test_return_address_tracking() {
    let mut debugger = Debugger::new()
    let ret_addr = 0x400500
    debugger.push_frame("foo", ret_addr)

    assert(debugger.call_stack[0].return_address == ret_addr,
           "return address must be stored")
}

// Test 20: DWARF version constant
fn test_dwarf_version() {
    let gen = DebugInfoGenerator::new()
    assert(gen.version == 5, "DWARF version must be 5")
}

fn assert(condition: bool, msg: string) {
    if !condition {
        panic("FAIL: " + msg)
    }
}

fn panic(msg: string) -> ! {
    return
}
