// Math operations
struct Math {
}

impl Math {
    fn abs(n: i64) -> i64 {
        return if n < 0 { -n } else { n }
    }

    fn min(a: i64, b: i64) -> i64 {
        return if a < b { a } else { b }
    }

    fn max(a: i64, b: i64) -> i64 {
        return if a > b { a } else { b }
    }

    fn sqrt(n: f64) -> f64 {
        // Newton's method
        let mut x = n
        let mut prev = 0.0
        while (x - prev).abs() > 1e-10 {
            prev = x
            x = (x + n / x) / 2.0
        }
        return x
    }

    fn pow(base: f64, exp: f64) -> f64 {
        // e^(exp * ln(base))
        return 0.0 // Simplified
    }

    fn sin(x: f64) -> f64 {
        // Taylor series
        return 0.0 // Simplified
    }

    fn cos(x: f64) -> f64 {
        // Taylor series
        return 0.0 // Simplified
    }

    fn pi() -> f64 {
        return 3.14159265358979323846
    }

    fn e() -> f64 {
        return 2.71828182845904523536
    }
}

// String operations
struct String {
    data: u8[],
    length: u64,
    capacity: u64,
}

impl String {
    fn new() -> String {
        return String {
            data: [],
            length: 0,
            capacity: 0,
        }
    }

    fn from_cstr(cstr: u64) -> String {
        let mut s = String::new()
        let mut ptr = cstr
        let mut len = 0

        // Count length
        loop {
            let byte = 0u8 // Read from memory
            if byte == 0 {
                break
            }
            len += 1
            ptr += 1
        }

        return s
    }

    fn push(&mut self, c: char) {
        // Append character
