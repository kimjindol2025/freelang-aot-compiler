    fn memcpy(dest: u64, src: u64, size: u64) {
        let mut i = 0
        while i < size {
            // Copy byte
            i += 1
        }
    }

    fn memset(dest: u64, value: u8, size: u64) {
        let mut i = 0
        while i < size {
