// Utility types
enum Option<T> {
    Some(value: T),
    None,
}

impl Option<T> {
    fn is_some(&self) -> bool {
        return match self {
            Some(_) => true,
            None => false,
        }
    }

    fn is_none(&self) -> bool {
        return match self {
            None => true,
            Some(_) => false,
        }
    }

    fn unwrap(&self) -> T {
        return match self {
            Some(v) => v,
            None => panic("unwrap on None"),
        }
    }
}

// Panic function
fn panic(msg: string) -> ! {
    IO::writeln("PANIC: " + msg)
    // syscall exit 1
}

// Assert
fn assert(condition: bool, msg: string) {
    if !condition {
        panic(msg)
    }
}

